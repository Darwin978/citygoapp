{
  "expo": {
    "name": "cityGoApp",
    "slug": "cityGoApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "cover",
      "backgroundColor": "#000000",
      "image": "./assets/negro.jpg"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.citygo"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.citygo",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBfVCCME9FaQG7zUd0xbeAQDehrYnFrpZA"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "aa054fc9-3b9d-4bae-b934-c1b960d00147"
      }
    }
  }
}